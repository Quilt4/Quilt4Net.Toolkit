@using Microsoft.Extensions.DependencyInjection
@using Quilt4Net.Toolkit.Blazor.Framework
@using Quilt4Net.Toolkit.Features.ApplicationInsights
@inject IServiceProvider Services
@implements IDisposable

@* One RadzenChart per metric. Samples are grouped by Series so each host (and, for disk, each
   filesystem) renders as its own line. Timestamps come back from KQL in UTC; convert to the
   browser's local timezone before binding so axis labels match what the operator sees on the
   clock. Empty/loading states share the same card shell so the grid doesn't reflow when data
   arrives. *@
<RadzenCard Style="padding: 1rem; min-height: 320px; display: flex; flex-direction: column;">
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" Style="margin-bottom: 0.5rem;">
        <RadzenText TextStyle="TextStyle.H6" Text="@Title" Style="margin: 0;" />
        @if (Loading)
        {
            <RadzenProgressBarCircular ProgressBarStyle="ProgressBarStyle.Primary" Size="ProgressBarCircularSize.Small" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
        }
    </RadzenStack>

    @if (_series.Count == 0)
    {
        <RadzenText TextStyle="TextStyle.Caption"
                    Text="@(Loading ? "Loading…" : "No data in the selected range.")"
                    Style="flex: 1; display: flex; align-items: center; justify-content: center; color: var(--rz-text-tertiary-color);" />
    }
    else
    {
        @* @key gives Blazor a new chart instance when axis flags flip, AND we explicitly call
           RadzenChart.Reload() in OnAfterRenderAsync when the key has just changed. Either path on
           its own proved unreliable across multiple sibling charts (Memory would update while CPU
           didn't, depending on render order); the belt-and-braces combination of "destroy +
           recreate via @key, then tell Radzen to recompute its axis scales via Reload" picks up
           the new Min/Max consistently. Data changes (Refresh, Range flip) don't change the key,
           so they don't trigger Reload — Radzen's normal re-render path handles those. *@
        <RadzenChart @ref="_chart" @key="@_chartKey" Style="flex: 1; min-height: 240px;">
            @foreach (var (label, points) in _series)
            {
                <RadzenLineSeries Data="@points" CategoryProperty="@nameof(MetricSample.Timestamp)" ValueProperty="@nameof(MetricSample.Value)" Title="@label" Smooth="true" />
            }
            <RadzenCategoryAxis FormatString="@_categoryFormat" />
            @if (LogScale)
            {
                @* Values were transformed to log10 in OnParametersSet; the axis lives in log
                   space so the Formatter reverse-transforms tick labels back to the natural unit
                   (0.01, 0.1, 1, 10, 100 …). Letting Radzen auto-scale the axis is fine — the
                   per-tick distance is already linear in log space. LogScale overrides
                   FullPercentScale because log10(0) is −∞ and a fixed 0..100 range loses meaning. *@
                <RadzenValueAxis Formatter="@FormatLogValue" />
            }
            else if (FullPercentScale)
            {
                @* Pinned 0..100 scale for percent metrics (CPU, memory). Stops the chart from
                   auto-scaling to a host's narrow band (e.g. "always between 8 and 12 %") and
                   making it look saturated when it's actually idle. *@
                <RadzenValueAxis FormatString="@($"{{0:0.##}} {Unit}")" Min="0d" Max="100d" />
            }
            else
            {
                <RadzenValueAxis FormatString="@($"{{0:0.##}} {Unit}")" />
            }
            <RadzenLegend Position="LegendPosition.Bottom" />
        </RadzenChart>
    }
</RadzenCard>

@code {
    [Parameter, EditorRequired] public string Title { get; set; }
    [Parameter] public string Unit { get; set; }
    [Parameter] public MetricSample[] Samples { get; set; } = [];
    [Parameter] public bool Loading { get; set; }

    /// <summary>
    /// When true, values are plotted on a logarithmic (base-10) scale. Useful when one or two
    /// hosts spike orders of magnitude above the others — on a linear axis the idle hosts squash
    /// into a flat line at the bottom; on log scale every host's shape is visible. Values are
    /// pre-transformed in <see cref="OnParametersSet"/> and the y-axis Formatter reverse-transforms
    /// tick labels so they read in the natural unit (10⁰=1, 10¹=10, 10²=100 …).
    /// </summary>
    [Parameter] public bool LogScale { get; set; }

    /// <summary>
    /// When true (default), pins the y-axis to the 0..100 range — appropriate for percent metrics
    /// like CPU and memory utilisation, where letting Radzen auto-scale would zoom into a narrow
    /// band (e.g. 8–12 %) and read as "saturated" when the host is actually idle. Ignored when
    /// <see cref="LogScale"/> is true (log10(0) is undefined and a fixed range loses meaning in
    /// log space).
    /// </summary>
    [Parameter] public bool FullPercentScale { get; set; } = true;

    /// <summary>
    /// Floor used when log-transforming values — anything ≤ this maps to log10(LogScaleEpsilon),
    /// so a host sitting at exactly 0 still plots at a finite y instead of −∞. Default 0.001
    /// (= 10⁻³) suits sub-1 MB/s network and similar small-magnitude metrics; raise it for metrics
    /// whose realistic floor is higher.
    /// </summary>
    [Parameter] public double LogScaleEpsilon { get; set; } = 0.001;

    private IReadOnlyList<(string Label, MetricSample[] Points)> _series = [];
    // Category-axis date/time format, chosen from the data's span: a 7-day window needs dates
    // (HH:mm alone repeats every midnight and is unreadable), a single day needs the time.
    private string _categoryFormat = "{0:HH:mm}";
    private IBrowserTimeZoneAccessor _browserTime; // optional — null when no host wires it up
    private string _chartKey = "linear-fullpct"; // recomputed in OnParametersSet; gates RadzenChart's @key
    private RadzenChart _chart; // captured via @ref so OnAfterRenderAsync can call Reload() on axis flips
    private string _lastReloadedKey = ""; // gate so we only Reload when the axis key actually changed

    protected override void OnInitialized()
    {
        _browserTime = Services.GetService<IBrowserTimeZoneAccessor>();
        if (_browserTime != null)
        {
            _browserTime.Changed += OnTimeZoneChanged;
        }
    }

    protected override void OnParametersSet()
    {
        // Key includes the chart Title so sibling MetricChart instances (CPU vs Memory in the
        // same view) get distinct keys — without that, two charts at adjacent positions with
        // identical keys created a Blazor-side ambiguity that left one of them un-re-keyed when
        // the toggle flipped. Also includes the axis-affecting flags so a fresh chart instance
        // is created on toggle. See the @key comment up top.
        _chartKey = $"{Title}-{(LogScale ? "log" : "lin")}-{(FullPercentScale ? "pct" : "auto")}";

        // Group the flat samples by Series so each line is one host (or host+device). Convert
        // each point's UTC timestamp to the browser's local zone (or, if no accessor is registered,
        // to the server's local zone — still better than UTC). When LogScale is on, also pre-
        // transform values to log10 space — RadzenChart's value axis is linear, so we trade one
        // round-trip through the values (log10 here, 10^x in the axis Formatter) for log-scale
        // plotting without depending on the chart library to support it natively.
        // Pick the axis label format from how much wall-clock the data covers: multi-day windows
        // show a date (otherwise every midnight reads identically), a day or less shows the time.
        var samples = Samples ?? [];
        if (samples.Length > 0)
        {
            var min = samples[0].Timestamp;
            var max = samples[0].Timestamp;
            foreach (var s in samples)
            {
                if (s.Timestamp < min) min = s.Timestamp;
                if (s.Timestamp > max) max = s.Timestamp;
            }
            var span = max - min;
            _categoryFormat = span > System.TimeSpan.FromDays(3) ? "{0:MMM dd}"
                : span > System.TimeSpan.FromDays(1) ? "{0:ddd HH:mm}"
                : "{0:HH:mm}";
        }

        var tz = _browserTime?.Current ?? System.TimeZoneInfo.Local;
        _series = (Samples ?? [])
            .GroupBy(s => s.Series ?? "")
            .OrderBy(g => g.Key, System.StringComparer.OrdinalIgnoreCase)
            .Select(g => (Label: g.Key, Points: g
                .OrderBy(s => s.Timestamp)
                .Select(s => s with
                {
                    Timestamp = ToLocal(s.Timestamp, tz),
                    Value = LogScale ? System.Math.Log10(System.Math.Max(s.Value, LogScaleEpsilon)) : s.Value,
                })
                .ToArray()))
            .ToList();
    }

    /// <summary>
    /// Reverse-transform tick labels from log10 space back to natural units so the axis reads
    /// "0.01 MB/s", "0.1 MB/s", "1 MB/s", "10 MB/s", "100 MB/s" instead of "−2", "−1", "0", "1", "2".
    /// </summary>
    private string FormatLogValue(object value)
    {
        if (value is null) return string.Empty;
        var d = System.Convert.ToDouble(value, System.Globalization.CultureInfo.InvariantCulture);
        var original = System.Math.Pow(10, d);
        // Sub-1 ticks show two decimals (0.01, 0.10) — anything ≥ 1 can drop the trailing zero.
        var fmt = original < 1 ? "0.##" : "0.#";
        return string.IsNullOrEmpty(Unit)
            ? original.ToString(fmt, System.Globalization.CultureInfo.CurrentCulture)
            : $"{original.ToString(fmt, System.Globalization.CultureInfo.CurrentCulture)} {Unit}";
    }

    private static System.DateTime ToLocal(System.DateTime utc, System.TimeZoneInfo tz)
    {
        // KQL hands timestamps back as Kind=Utc; coerce anything else explicitly so the offset
        // math is unambiguous. The returned DateTime has Kind=Unspecified, which Radzen happily
        // formats with the FormatString we pass on the category axis.
        if (utc.Kind != System.DateTimeKind.Utc)
            utc = System.DateTime.SpecifyKind(utc, System.DateTimeKind.Utc);
        return System.TimeZoneInfo.ConvertTimeFromUtc(utc, tz);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // After Blazor has rendered the chart with the new (post-toggle) axis configuration,
        // ask Radzen to recompute its scales. Reload() re-reads the registered axes and
        // re-projects the series — without this, RadzenChart sometimes holds onto the first-
        // render axis bounds even after @key recreated the component.
        if (_chart != null && _lastReloadedKey != _chartKey)
        {
            _lastReloadedKey = _chartKey;
            await _chart.Reload();
        }
    }

    private void OnTimeZoneChanged()
    {
        // First load resolves after the chart already rendered with UTC; re-project samples in
        // the new zone and force a redraw. Marshals to the UI thread — Changed fires from the
        // JS-interop completion, which can be on a worker context.
        InvokeAsync(() =>
        {
            OnParametersSet();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        if (_browserTime != null) _browserTime.Changed -= OnTimeZoneChanged;
    }
}
