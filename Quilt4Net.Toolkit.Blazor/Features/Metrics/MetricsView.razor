@using Microsoft.Extensions.DependencyInjection
@using Quilt4Net.Toolkit.Blazor.Features.ApplicationInsights
@using Quilt4Net.Toolkit.Blazor.Framework
@using Quilt4Net.Toolkit.Features.ApplicationInsights
@inject IServiceProvider ServiceProvider
@inject IApplicationInsightsService Ai
@implements IDisposable

@if (_configError != null)
{
    <RadzenAlert AlertStyle="AlertStyle.Info" Shade="Shade.Lighter" AllowClose="false">@_configError</RadzenAlert>
    return;
}

<RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
    <RadzenRow AlignItems="AlignItems.End" Gap="1rem">
        @if (_selector != null && _selector.Available.Count > 1)
        {
            <RadzenColumn>
                <ApplicationInsightsConfigurationDropdown />
            </RadzenColumn>
        }
        else if (Configs is { Count: > 1 })
        {
            <RadzenColumn>
                <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                    <RadzenText TextStyle="TextStyle.Caption" Text="Configuration" />
                    <RadzenDropDown Data="@Configs" @bind-Value="_selectedConfig" TValue="ApplicationInsightsConfigurationResponse"
                                    TextProperty="Name" Change="@(_ => ReloadAsync())" />
                </RadzenStack>
            </RadzenColumn>
        }
        <RadzenColumn>
            <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                <RadzenText TextStyle="TextStyle.Caption" Text="Range" />
                <RadzenSelectBar @bind-Value="_window" TValue="System.TimeSpan" Size="ButtonSize.Small"
                                 Change="@(_ => ReloadAsync())">
                    <Items>
                        <RadzenSelectBarItem Text="1h" Value="@System.TimeSpan.FromHours(1)" />
                        <RadzenSelectBarItem Text="24h" Value="@System.TimeSpan.FromHours(24)" />
                        <RadzenSelectBarItem Text="7d" Value="@System.TimeSpan.FromDays(7)" />
                    </Items>
                </RadzenSelectBar>
            </RadzenStack>
        </RadzenColumn>
        <RadzenColumn>
            <RadzenButton Icon="refresh" Text="Refresh" ButtonStyle="ButtonStyle.Light"
                          IsBusy="@_busy" Click="@(_ => ReloadAsync())" />
        </RadzenColumn>
    </RadzenRow>

    @if (_loadError != null)
    {
        <RadzenAlert AlertStyle="AlertStyle.Warning" Shade="Shade.Lighter" AllowClose="false">
            Could not query Application Insights: @_loadError
        </RadzenAlert>
    }

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(420px, 1fr)); gap: 1rem;">
        <MetricChart Title="CPU %" Unit="%" Samples="@_cpu" Loading="@_busy" />
        <MetricChart Title="Memory %" Unit="%" Samples="@_memory" Loading="@_busy" />
        <MetricChart Title="Disk free (GB)" Unit="GB" Samples="@_disk" Loading="@_busy" />
        <MetricChart Title="Network (MB/s)" Unit="MB/s" Samples="@_network" Loading="@_busy" />
    </div>
</RadzenStack>

@code {
    private string _configError;
    private string _loadError;
    private bool _busy;
    private System.TimeSpan _window = System.TimeSpan.FromHours(1);

    private MetricSample[] _cpu = [];
    private MetricSample[] _memory = [];
    private MetricSample[] _disk = [];
    private MetricSample[] _network = [];

    private IApplicationInsightsConfigurationSelector _selector;
    private ApplicationInsightsConfigurationResponse _selectedConfig;

    /// <summary>Optional explicit context. When set, the selector is ignored.</summary>
    [Parameter]
    public IApplicationInsightsContext Context { get; set; }

    /// <summary>
    /// Optional explicit set of configurations to pick from. When more than one is supplied a
    /// dropdown is rendered. Takes precedence over the DI selector; ignored when <see cref="Context"/>
    /// is set. Mirrors the same parameter on <c>LogView</c> so the two compose on the same page.
    /// </summary>
    [Parameter]
    public IReadOnlyList<ApplicationInsightsConfigurationResponse> Configs { get; set; }

    private IApplicationInsightsContext EffectiveContext
        => Context ?? _selectedConfig ?? _selector?.Selected;

    protected override async Task OnInitializedAsync()
    {
        // Explicit Context / Configs bypass the DI selector entirely.
        if (Context == null && Configs is not { Count: > 0 })
        {
            _selector = ServiceProvider.GetService<IApplicationInsightsConfigurationSelector>();
            if (_selector != null)
            {
                _selector.OnChanged += OnSelectorChanged;
                if (!_selector.IsLoaded)
                {
                    await _selector.LoadAsync();
                }
            }
        }

        if (Configs is { Count: > 0 } && _selectedConfig == null)
        {
            _selectedConfig = Configs[0];
        }

        if (EffectiveContext == null)
        {
            _configError = "No Application Insights configuration available.";
            return;
        }

        await ReloadAsync();
    }

    private async void OnSelectorChanged()
    {
        await InvokeAsync(ReloadAsync);
    }

    private async Task ReloadAsync()
    {
        var ctx = EffectiveContext;
        if (ctx == null) return;
        _busy = true;
        _loadError = null;
        StateHasChanged();
        try
        {
            // Sequential, not parallel — keeps the AI query rate-limit polite. Charts paint as
            // each completes via StateHasChanged between awaits.
            _cpu = await Ai.GetCpuUtilizationAsync(ctx, _window).ToArrayAsync();
            StateHasChanged();
            _memory = await Ai.GetMemoryUtilizationAsync(ctx, _window).ToArrayAsync();
            StateHasChanged();
            _disk = await Ai.GetDiskFreeAsync(ctx, _window).ToArrayAsync();
            StateHasChanged();
            _network = await Ai.GetNetworkThroughputAsync(ctx, _window).ToArrayAsync();
        }
        catch (System.Exception e)
        {
            _loadError = e.Message;
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // JS interop is unavailable during prerender, so the browser timezone lookup runs
            // here on the first interactive render. The accessor is optional in DI: when a host
            // doesn't call AddQuilt4NetBlazorContent or AddQuilt4NetBlazorApplicationInsightsClient-
            // Remote, the charts simply fall back to TimeZoneInfo.Local (handled in MetricChart).
            var browserTime = ServiceProvider.GetService<IBrowserTimeZoneAccessor>();
            if (browserTime != null)
            {
                await browserTime.EnsureLoadedAsync();
            }
        }
    }

    public void Dispose()
    {
        if (_selector != null) _selector.OnChanged -= OnSelectorChanged;
    }
}
