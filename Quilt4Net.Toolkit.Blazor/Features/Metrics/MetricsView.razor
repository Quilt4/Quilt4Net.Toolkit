@using Microsoft.Extensions.DependencyInjection
@using Quilt4Net.Toolkit.Blazor.Features.ApplicationInsights
@using Quilt4Net.Toolkit.Blazor.Framework
@using Quilt4Net.Toolkit.Features.ApplicationInsights
@inject IServiceProvider ServiceProvider
@inject IApplicationInsightsService Ai
@implements System.IDisposable

@if (_configError != null)
{
    <RadzenAlert AlertStyle="AlertStyle.Info" Shade="Shade.Lighter" AllowClose="false">@_configError</RadzenAlert>
    return;
}

<RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
    @* RadzenStack horizontal + FlexWrap.Wrap so each filter sizes to its content and the row
       reflows onto extra lines as the window narrows — same shape as LogCountByServiceView /
       VersionMatrixDisplay / /monitor/log. *@
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.End" Gap="1rem" Wrap="FlexWrap.Wrap">
        @if (_selector != null && _selector.Available.Count > 1)
        {
            <ApplicationInsightsConfigurationDropdown />
        }
        else if (Configs is { Count: > 1 })
        {
            <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                <RadzenText TextStyle="TextStyle.Caption" Text="Configuration" />
                <RadzenDropDown Data="@Configs" @bind-Value="_selectedConfig" TValue="ApplicationInsightsConfigurationResponse"
                                TextProperty="Name" Change="@(_ => ReloadAsync(force: false))" />
            </RadzenStack>
        }
        <RadzenStack Orientation="Orientation.Vertical" Gap="0">
            <RadzenText TextStyle="TextStyle.Caption" Text="Range" />
            <RadzenSelectBar @bind-Value="_window" TValue="System.TimeSpan" Size="ButtonSize.Small"
                             Change="@(_ => ReloadAsync(force: false))">
                <Items>
                    <RadzenSelectBarItem Text="1h" Value="@System.TimeSpan.FromHours(1)" />
                    <RadzenSelectBarItem Text="24h" Value="@System.TimeSpan.FromHours(24)" />
                    <RadzenSelectBarItem Text="7d" Value="@System.TimeSpan.FromDays(7)" />
                </Items>
            </RadzenSelectBar>
        </RadzenStack>
        @* Test toggle: forwards to FullPercentScale on the CPU/Memory charts. Flipping it doesn't
           re-fetch data — the Y-axis just redraws against a fixed 0..100 vs auto-scaled range. *@
        @* <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.4rem">
            <RadzenSwitch @bind-Value="_fullPercentScale" TValue="bool" Name="fullPercentScale" />
            <RadzenLabel Component="fullPercentScale" Text="0–100 % scale" />
        </RadzenStack> *@
        @* Native `title` tooltip — DataAgeFormat reports the absolute load timestamp (restored
           from the scoped cache on page-navigation revisit) so the text doesn't go stale between
           renders the way a relative "X minutes ago" string would. *@
        <RadzenButton Icon="refresh" Text="Refresh" ButtonStyle="ButtonStyle.Light"
                      IsBusy="@_busy"
                      title="@DataAgeFormat.Describe(_lastRefreshUtc, _browserTime?.Current, _cacheTtl)"
                      Click="@(_ => ReloadAsync(force: true))" />
    </RadzenStack>

    @if (_loadError != null)
    {
        <RadzenAlert AlertStyle="AlertStyle.Warning" Shade="Shade.Lighter" AllowClose="false">
            Could not query Application Insights: @_loadError
        </RadzenAlert>
    }

    <RadzenText TextStyle="TextStyle.H6" Text="Hosts" Style="margin: 0;" />
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(420px, 1fr)); gap: 1rem;">
        <MetricChart Title="CPU %" Unit="%" Samples="@_cpu" Loading="@_busy" FullPercentScale="@_fullPercentScale" />
        <MetricChart Title="Memory %" Unit="%" Samples="@_memory" Loading="@_busy" FullPercentScale="@_fullPercentScale" />
        @* Disk used uses a bar-per-host snapshot — over a 1h/24h/7d window the value barely
           moves so a line chart degenerates into N flat lines. The bar fills as the volume fills
           up (longer = more used), and the chart's LessIsBad=false threshold logic turns the bar
           amber over 80% and red over 90% of capacity. The delta badge (▲ +1.2 GB / 24h) signals
           growth with a utilisation-is-bad colour scheme; the inline sparkline keeps the shape
           visible for cases where a sudden spike matters. *@
        <MetricLatestChart Title="Disk used (GB)" Unit="GB" Samples="@_disk" Capacity="@_diskCapacity" Range="@_window" Loading="@_busy" LessIsBad="false" />
    </div>

    @* Cluster section — Kubernetes node metrics (kubeletstats). Only shown when the workspace
       actually has node telemetry, so non-cluster consumers don't see an empty section. CPU is
       absolute cores (no node CPU-capacity metric to percentage against); memory and filesystem
       are % of node total. *@
    @if (_busy || _nodes.Length > 0)
    {
        <RadzenText TextStyle="TextStyle.H6" Text="Cluster nodes" Style="margin: 0.5rem 0 0 0;" />
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(420px, 1fr)); gap: 1rem;">
            <MetricChart Title="Node CPU (cores)" Unit="cores" Samples="@_nodeCpu" Loading="@_busy" FullPercentScale="false" />
            <MetricChart Title="Node memory %" Unit="%" Samples="@_nodeMemory" Loading="@_busy" FullPercentScale="@_fullPercentScale" />
            <MetricChart Title="Node filesystem %" Unit="%" Samples="@_nodeFilesystem" Loading="@_busy" FullPercentScale="@_fullPercentScale" />
        </div>

        @* Node→pod drill-down: pick a node to load the pods scheduled on it. Pod series are
           fetched on demand (not part of the scoped cache) since they're a detail view. *@
        @if (_nodes.Length > 0)
        {
            <RadzenStack Orientation="Orientation.Vertical" Gap="0" Style="margin-top: 0.5rem;">
                <RadzenText TextStyle="TextStyle.Caption" Text="Drill into node (pods)" />
                <RadzenDropDown Data="@_nodes" @bind-Value="_selectedNode" TValue="string"
                                AllowClear="true" Placeholder="Select a node…"
                                Change="@(_ => LoadPodsAsync())" Style="max-width: 320px;" />
            </RadzenStack>

            @if (!string.IsNullOrEmpty(_selectedNode))
            {
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(420px, 1fr)); gap: 1rem;">
                    <MetricChart Title="@($"Pods on {_selectedNode} — CPU (cores)")" Unit="cores" Samples="@_podCpu" Loading="@_podBusy" FullPercentScale="false" />
                    <MetricChart Title="@($"Pods on {_selectedNode} — memory (MB)")" Unit="MB" Samples="@_podMemory" Loading="@_podBusy" FullPercentScale="false" />
                </div>
            }
        }
    }
</RadzenStack>

@code {
    private string _configError;
    private string _loadError;
    private bool _busy;
    private System.DateTime? _lastRefreshUtc;
    private static readonly System.TimeSpan _cacheTtl = System.TimeSpan.FromMinutes(10);
    private System.TimeSpan _window = System.TimeSpan.FromHours(1);
    // Default ON — matches the new MetricChart default. Wired to the page's "0–100 % scale" switch
    // so testers can toggle the axis pinning live without code changes.
    private bool _fullPercentScale = true;

    private MetricSample[] _cpu = [];
    private MetricSample[] _memory = [];
    private MetricSample[] _disk = [];
    private DiskCapacity[] _diskCapacity = [];

    // Cluster node series + node→pod drill-down state.
    private MetricSample[] _nodeCpu = [];
    private MetricSample[] _nodeMemory = [];
    private MetricSample[] _nodeFilesystem = [];
    private string[] _nodes = [];
    private string _selectedNode;
    private MetricSample[] _podCpu = [];
    private MetricSample[] _podMemory = [];
    private bool _podBusy;

    private IApplicationInsightsConfigurationSelector _selector;
    private ApplicationInsightsConfigurationResponse _selectedConfig;
    private MetricsSeriesCache _scopedCache;
    private IBrowserTimeZoneAccessor _browserTime;

    /// <summary>Optional explicit context. When set, the selector is ignored.</summary>
    [Parameter]
    public IApplicationInsightsContext Context { get; set; }

    /// <summary>
    /// Optional explicit set of configurations to pick from. When more than one is supplied a
    /// dropdown is rendered. Takes precedence over the DI selector; ignored when <see cref="Context"/>
    /// is set. Mirrors the same parameter on <c>LogView</c> so the two compose on the same page.
    /// </summary>
    [Parameter]
    public IReadOnlyList<ApplicationInsightsConfigurationResponse> Configs { get; set; }

    private IApplicationInsightsContext EffectiveContext
        => Context ?? _selectedConfig ?? _selector?.Selected;

    protected override async Task OnInitializedAsync()
    {
        // Scoped cache: per-circuit so the four series + load timestamp survive page navigation.
        // Optional — hosts that didn't call AddQuilt4NetBlazorApplicationInsightsClientRemote
        // still work, they just lose cross-page persistence.
        _scopedCache = ServiceProvider.GetService<MetricsSeriesCache>();
        _browserTime = ServiceProvider.GetService<IBrowserTimeZoneAccessor>();

        // Explicit Context / Configs bypass the DI selector entirely.
        if (Context == null && Configs is not { Count: > 0 })
        {
            _selector = ServiceProvider.GetService<IApplicationInsightsConfigurationSelector>();
            if (_selector != null)
            {
                _selector.OnChanged += OnSelectorChanged;
                if (!_selector.IsLoaded)
                {
                    await _selector.LoadAsync();
                }
            }
        }

        if (Configs is { Count: > 0 } && _selectedConfig == null)
        {
            _selectedConfig = Configs[0];
        }

        if (EffectiveContext == null)
        {
            _configError = "No Application Insights configuration available.";
            return;
        }

        await ReloadAsync(force: false);
    }

    private async void OnSelectorChanged()
    {
        await InvokeAsync(() => ReloadAsync(force: false));
    }

    private async Task ReloadAsync(bool force)
    {
        var ctx = EffectiveContext;
        if (ctx == null) return;
        var key = MetricsSeriesCache.KeyForContext(ctx);

        if (force)
        {
            _scopedCache?.Invalidate(key, _window);
        }

        // Cache hit: render immediately and skip the spinner. The restored LoadedUtc keeps the
        // refresh-button tooltip honest ("Data loaded at 14:03:11") across page navigations.
        if (!force && _scopedCache != null && _scopedCache.TryGet(key, _window, _cacheTtl, out var entry))
        {
            _cpu = entry.Cpu;
            _memory = entry.Memory;
            _disk = entry.Disk;
            _diskCapacity = entry.DiskCapacity;
            _nodeCpu = entry.NodeCpu;
            _nodeMemory = entry.NodeMemory;
            _nodeFilesystem = entry.NodeFilesystem;
            _nodes = NodeNames(_nodeCpu);
            _lastRefreshUtc = entry.LoadedUtc;
            _loadError = null;
            _busy = false;
            StateHasChanged();
            return;
        }

        _busy = true;
        _loadError = null;
        StateHasChanged();
        try
        {
            // Sequential, not parallel — keeps the AI query rate-limit polite. Charts paint as
            // each completes via StateHasChanged between awaits.
            _cpu = await Ai.GetCpuUtilizationAsync(ctx, _window).ToArrayAsync();
            StateHasChanged();
            _memory = await Ai.GetMemoryUtilizationAsync(ctx, _window).ToArrayAsync();
            StateHasChanged();
            var freeSamples = await Ai.GetDiskFreeAsync(ctx, _window).ToArrayAsync();
            StateHasChanged();
            // Capacity is sequenced with the other queries so a single-query failure can't leave
            // the bars half-rendered. It's quick — one KQL pass that aggregates per volume.
            _diskCapacity = await Ai.GetDiskCapacityAsync(ctx, _window).ToArrayAsync();
            // The server still queries disk-free (operator-meaningful in the KQL view), but the UI
            // shows disk-used so the bar fills as the volume fills. We transform per series here
            // because the cache stores whatever we display, and we want a cache hit to skip the
            // capacity-join the second time.
            _disk = ToDiskUsed(freeSamples, _diskCapacity);
            StateHasChanged();
            // Cluster node series (kubeletstats). Empty on non-cluster workspaces — the Cluster
            // section then collapses to nothing.
            _nodeCpu = await Ai.GetClusterNodeCpuAsync(ctx, _window).ToArrayAsync();
            _nodes = NodeNames(_nodeCpu);
            StateHasChanged();
            _nodeMemory = await Ai.GetClusterNodeMemoryAsync(ctx, _window).ToArrayAsync();
            StateHasChanged();
            _nodeFilesystem = await Ai.GetClusterNodeFilesystemAsync(ctx, _window).ToArrayAsync();
            StateHasChanged();
            // A previously-selected node may no longer exist after a reload — drop the drill-down
            // if so, otherwise refresh its pods for the new window.
            if (!string.IsNullOrEmpty(_selectedNode) && !_nodes.Contains(_selectedNode))
            {
                _selectedNode = null;
                _podCpu = [];
                _podMemory = [];
            }
            else if (!string.IsNullOrEmpty(_selectedNode))
            {
                await LoadPodsAsync();
            }
            // Stamp the load completion. Only on success — a failed load shouldn't claim freshness.
            var loadedUtc = System.DateTime.UtcNow;
            _lastRefreshUtc = loadedUtc;
            _scopedCache?.Set(key, _window, _cpu, _memory, _disk, _diskCapacity, _nodeCpu, _nodeMemory, _nodeFilesystem, loadedUtc);
        }
        catch (System.Exception e)
        {
            _loadError = e.Message;
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // JS interop is unavailable during prerender, so the browser timezone lookup runs
            // here on the first interactive render. The accessor is optional in DI: when a host
            // doesn't call AddQuilt4NetBlazorContent or AddQuilt4NetBlazorApplicationInsightsClient-
            // Remote, the charts simply fall back to TimeZoneInfo.Local (handled in MetricChart).
            var browserTime = ServiceProvider.GetService<IBrowserTimeZoneAccessor>();
            if (browserTime != null)
            {
                await browserTime.EnsureLoadedAsync();
            }
        }
    }

    public void Dispose()
    {
        if (_selector != null) _selector.OnChanged -= OnSelectorChanged;
    }

    /// <summary>Distinct node names (sorted) from a node series, for the drill-down dropdown.</summary>
    private static string[] NodeNames(MetricSample[] nodeSamples)
        => MetricsViewLogic.NodeNames(nodeSamples);

    /// <summary>
    /// Load the pod CPU/memory series for the currently selected node. Cleared and skipped when
    /// no node is selected (the AllowClear dropdown sets it to null). Errors surface in the same
    /// banner as the main load; pod charts just stay empty.
    /// </summary>
    private async Task LoadPodsAsync()
    {
        var ctx = EffectiveContext;
        if (ctx == null || string.IsNullOrEmpty(_selectedNode))
        {
            _podCpu = [];
            _podMemory = [];
            StateHasChanged();
            return;
        }

        _podBusy = true;
        StateHasChanged();
        try
        {
            _podCpu = await Ai.GetClusterPodCpuAsync(ctx, _selectedNode, _window).ToArrayAsync();
            StateHasChanged();
            _podMemory = await Ai.GetClusterPodMemoryAsync(ctx, _selectedNode, _window).ToArrayAsync();
        }
        catch (System.Exception e)
        {
            _loadError = e.Message;
        }
        finally
        {
            _podBusy = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Turn a disk-free series into disk-used by subtracting each sample's value from the volume's
    /// total capacity (joined on <see cref="MetricSample.Series"/>). Volumes with no matching
    /// capacity entry fall through to their original free value — a degraded state, but the
    /// alternative is dropping the row entirely which is worse for the operator. Negative deltas
    /// (free &gt; reported capacity, possible during a brief capacity expansion window) clamp to 0.
    /// </summary>
    private static MetricSample[] ToDiskUsed(MetricSample[] freeSamples, DiskCapacity[] capacities)
    {
        if (freeSamples == null || freeSamples.Length == 0) return [];

        var capacityByVolume = (capacities ?? [])
            .Where(c => c.TotalGb > 0)
            .GroupBy(c => c.Series ?? "", System.StringComparer.OrdinalIgnoreCase)
            .ToDictionary(g => g.Key, g => g.First().TotalGb, System.StringComparer.OrdinalIgnoreCase);

        var transformed = new MetricSample[freeSamples.Length];
        for (var i = 0; i < freeSamples.Length; i++)
        {
            var s = freeSamples[i];
            if (capacityByVolume.TryGetValue(s.Series ?? "", out var total))
            {
                var used = total - s.Value;
                if (used < 0) used = 0;
                transformed[i] = s with { Value = used };
            }
            else
            {
                transformed[i] = s;        // no capacity → leave the value alone
            }
        }
        return transformed;
    }
}
