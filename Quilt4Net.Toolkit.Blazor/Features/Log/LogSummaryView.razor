@using Quilt4Net.Toolkit.Features.ApplicationInsights

@if (_params != null && _params.GetSource().HasValue && _params.GetRange() != TimeSpan.Zero)
{
    <CascadingValue Value="_navOptions">
        <LogSummaryContent Fingerprint="@Fingerprint"
                           Environment="@_params.Environment"
                           Range="@_params.GetRange()"
                           Source="@_params.GetSource()"
                           Context="@_params.GetContext()" />
    </CascadingValue>
}

@code {
    private LogNavParams _params;
    private LogNavigationOptions _navOptions;

    /// <summary>
    /// The fingerprint identifying the log summary group.
    /// Typically bound from a route parameter: <c>@page "/log/summary/{Fingerprint}"</c>
    /// </summary>
    [Parameter]
    public string Fingerprint { get; set; }

    /// <summary>
    /// URL-safe base64-encoded navigation parameters produced by <see cref="LogNavParams.Encode"/>.
    /// Typically bound from a query parameter: <c>[Parameter, SupplyParameterFromQuery] public string P { get; set; }</c>
    /// </summary>
    [Parameter]
    public string Params { get; set; }

    /// <summary>
    /// Optional path for the log detail page, e.g. "/log/detail".
    /// When null (default), clicking a detail link opens a dialog instead of navigating.
    /// </summary>
    [Parameter]
    public string DetailPath { get; set; }

    protected override void OnParametersSet()
    {
        _params = LogNavParams.Decode(Params);
        _navOptions = new LogNavigationOptions
        {
            DetailPath = DetailPath
        };
    }
}
