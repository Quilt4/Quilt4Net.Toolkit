@using Microsoft.Extensions.DependencyInjection
@using Microsoft.Extensions.Options
@using Quilt4Net.Toolkit.Blazor.Features.ApplicationInsights
@using Quilt4Net.Toolkit.Features.ApplicationInsights
@inject IServiceProvider ServiceProvider
@inject IApplicationInsightsService Ai
@inject IOptions<ApplicationInsightsOptions> AiOptions
@implements IDisposable

@* Pivot of log counts: rows = services, columns = severity. Configuration / Environment / Source
   are all multi-select with "nothing selected = include all" semantics; only Range changes hit
   AI — every other filter toggle is a local regroup over the cell cube already in memory. Each
   distinct Range is cached for the lifetime of the circuit so flipping back to 1h after 24h is
   instant. *@

@if (_configError != null)
{
    <RadzenAlert AlertStyle="AlertStyle.Info" Shade="Shade.Lighter" AllowClose="false">@_configError</RadzenAlert>
    return;
}

<RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
    <RadzenRow AlignItems="AlignItems.End" Gap="1rem">
        @if (_candidateConfigs.Count > 1)
        {
            <RadzenColumn>
                <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                    <RadzenText TextStyle="TextStyle.Caption" Text="Configuration (none = all)" />
                    <RadzenSelectBar @bind-Value="_selectedConfigIds" TValue="IEnumerable<string>" Multiple="true" Size="ButtonSize.Small"
                                     Change="@(_ => RecomputeRows())">
                        <Items>
                            @foreach (var c in _candidateConfigs)
                            {
                                <RadzenSelectBarItem Text="@c.Name" Value="@c.Id" />
                            }
                        </Items>
                    </RadzenSelectBar>
                </RadzenStack>
            </RadzenColumn>
        }
        <RadzenColumn>
            <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                <RadzenText TextStyle="TextStyle.Caption" Text="Range" />
                <RadzenSelectBar @bind-Value="_window" TValue="System.TimeSpan" Size="ButtonSize.Small"
                                 Change="@(_ => OnRangeChangedAsync())">
                    <Items>
                        <RadzenSelectBarItem Text="1h" Value="@System.TimeSpan.FromHours(1)" />
                        <RadzenSelectBarItem Text="24h" Value="@System.TimeSpan.FromHours(24)" />
                        <RadzenSelectBarItem Text="7d" Value="@System.TimeSpan.FromDays(7)" />
                    </Items>
                </RadzenSelectBar>
            </RadzenStack>
        </RadzenColumn>
        @if (_candidateEnvironments.Count > 0)
        {
            <RadzenColumn>
                <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                    <RadzenText TextStyle="TextStyle.Caption" Text="Environment (none = all)" />
                    <RadzenSelectBar @bind-Value="_selectedEnvironments" TValue="IEnumerable<string>" Multiple="true" Size="ButtonSize.Small"
                                     Change="@(_ => RecomputeRows())">
                        <Items>
                            @foreach (var env in _candidateEnvironments)
                            {
                                <RadzenSelectBarItem Text="@env" Value="@env" />
                            }
                        </Items>
                    </RadzenSelectBar>
                </RadzenStack>
            </RadzenColumn>
        }
        <RadzenColumn>
            <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                <RadzenText TextStyle="TextStyle.Caption" Text="Source (none = all)" />
                <RadzenSelectBar @bind-Value="_selectedSources" TValue="IEnumerable<LogSource>" Multiple="true" Size="ButtonSize.Small"
                                 Change="@(_ => RecomputeRows())">
                    <Items>
                        <RadzenSelectBarItem Text="Trace" Value="LogSource.Trace" />
                        <RadzenSelectBarItem Text="Exception" Value="LogSource.Exception" />
                        <RadzenSelectBarItem Text="Request" Value="LogSource.Request" />
                    </Items>
                </RadzenSelectBar>
            </RadzenStack>
        </RadzenColumn>
        <RadzenColumn>
            <RadzenButton Icon="refresh" Text="Refresh" ButtonStyle="ButtonStyle.Light"
                          IsBusy="@_busy" Click="@(_ => ReloadAsync(force: true))" />
        </RadzenColumn>
    </RadzenRow>

    @if (_loadError != null)
    {
        <RadzenAlert AlertStyle="AlertStyle.Warning" Shade="Shade.Lighter" AllowClose="false">
            Could not query Application Insights: @_loadError
        </RadzenAlert>
    }

    @if (_busy)
    {
        <Loading />
    }
    else if (_rows.Count == 0)
    {
        <RadzenAlert AlertStyle="AlertStyle.Info" Shade="Shade.Lighter" AllowClose="false">
            No log entries in the selected range / filter combination.
        </RadzenAlert>
    }
    else
    {
        <RadzenDataGrid Data="@_rows" TItem="ServiceRow" AllowSorting="true">
            <Columns>
                <RadzenDataGridColumn TItem="ServiceRow" Title="Service" Property="@nameof(ServiceRow.Service)" SortOrder="SortOrder.Ascending">
                    <FooterTemplate><strong>Total</strong></FooterTemplate>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="ServiceRow" Title="Verbose" Property="@nameof(ServiceRow.Verbose)" Width="120px" TextAlign="TextAlign.Right" FormatString="{0:N0}">
                    <FooterTemplate><strong>@_columnTotals[SeverityLevel.Verbose].ToString("N0")</strong></FooterTemplate>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="ServiceRow" Title="Information" Property="@nameof(ServiceRow.Information)" Width="140px" TextAlign="TextAlign.Right" FormatString="{0:N0}">
                    <FooterTemplate><strong>@_columnTotals[SeverityLevel.Information].ToString("N0")</strong></FooterTemplate>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="ServiceRow" Title="Warning" Property="@nameof(ServiceRow.Warning)" Width="120px" TextAlign="TextAlign.Right" FormatString="{0:N0}">
                    <FooterTemplate><strong>@_columnTotals[SeverityLevel.Warning].ToString("N0")</strong></FooterTemplate>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="ServiceRow" Title="Error" Property="@nameof(ServiceRow.Error)" Width="120px" TextAlign="TextAlign.Right" FormatString="{0:N0}">
                    <FooterTemplate><strong>@_columnTotals[SeverityLevel.Error].ToString("N0")</strong></FooterTemplate>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="ServiceRow" Title="Critical" Property="@nameof(ServiceRow.Critical)" Width="120px" TextAlign="TextAlign.Right" FormatString="{0:N0}">
                    <FooterTemplate><strong>@_columnTotals[SeverityLevel.Critical].ToString("N0")</strong></FooterTemplate>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="ServiceRow" Title="Total" Property="@nameof(ServiceRow.Total)" Width="120px" TextAlign="TextAlign.Right" FormatString="{0:N0}">
                    <FooterTemplate><strong>@_grandTotal.ToString("N0")</strong></FooterTemplate>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    }
</RadzenStack>

@code {
    private string _configError;
    private string _loadError;
    private bool _busy;
    private System.TimeSpan _window = System.TimeSpan.FromHours(24);

    // Candidate sets (everything offered by the AI workspaces) — separate from the user's picks.
    private IReadOnlyList<ApplicationInsightsConfigurationResponse> _candidateConfigs = [];
    private IReadOnlyList<string> _candidateEnvironments = [];

    // Current user selections. Empty enumerable everywhere means "include all".
    private IEnumerable<string> _selectedConfigIds = [];
    private IEnumerable<string> _selectedEnvironments = [];
    private IEnumerable<LogSource> _selectedSources = [];

    // Per-range cache of every cell fetched from AI (across every candidate config). Filter
    // changes recompute _rows from this map — no fetch. Range changes look up / populate it.
    // Each cell is tagged with its owning config id so the configuration filter is local too.
    private readonly Dictionary<System.TimeSpan, List<TaggedCell>> _cellCache = new();

    // Output of the current filter combination — what the grid binds to + the pinned totals row.
    private List<ServiceRow> _rows = [];
    private Dictionary<SeverityLevel, long> _columnTotals = NewEmptyTotals();
    private long _grandTotal;

    private IApplicationInsightsConfigurationSelector _selector;

    /// <summary>Optional explicit context. When set, the configuration multi-select is bypassed.</summary>
    [Parameter]
    public IApplicationInsightsContext Context { get; set; }

    /// <summary>
    /// Optional explicit set of configurations. Multi-select bar lists these; "nothing selected"
    /// means aggregate across all. Takes precedence over the DI selector; ignored when
    /// <see cref="Context"/> is set.
    /// </summary>
    [Parameter]
    public IReadOnlyList<ApplicationInsightsConfigurationResponse> Configs { get; set; }

    /// <summary>
    /// Preferred display order for environments. Named entries come first in the supplied order;
    /// any extras the AI workspace surfaces fall back to alphabetical. When null,
    /// <see cref="EnvironmentOrdering.DefaultOrder"/> (Development, CI, Staging, Test, Production)
    /// is used. Hosts that pull a team-specific order from their own config — e.g. via
    /// <c>IEnvironmentService</c> on Quilt4Net.Server — should pass it here.
    /// </summary>
    [Parameter]
    public IReadOnlyList<string> EnvironmentOrder { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // _busy stays true through env discovery + the first fetch so the loading spinner is the
        // only thing on screen between component mount and the data landing.
        _busy = true;
        StateHasChanged();

        try
        {
            // Resolve the candidate-config set first — explicit Context bypasses selection.
            if (Context == null)
            {
                if (Configs is { Count: > 0 })
                {
                    _candidateConfigs = Configs;
                }
                else
                {
                    _selector = ServiceProvider.GetService<IApplicationInsightsConfigurationSelector>();
                    if (_selector != null)
                    {
                        _selector.OnChanged += OnSelectorChanged;
                        if (!_selector.IsLoaded) await _selector.LoadAsync();
                        _candidateConfigs = _selector.Available ?? [];
                    }
                }

                if (_candidateConfigs.Count == 0)
                {
                    _configError = "No Application Insights configuration available.";
                    _busy = false;
                    return;
                }
            }

            await LoadEnvironmentsAsync();
            await ReloadAsync(force: false);
        }
        finally
        {
            // ReloadAsync clears _busy on success; this guards the early returns and exceptions.
            _busy = false;
            StateHasChanged();
        }
    }

    private async void OnSelectorChanged() => await InvokeAsync(async () =>
    {
        _candidateConfigs = _selector?.Available ?? [];
        _cellCache.Clear(); // workspaces changed; previous fetches are no longer authoritative
        await LoadEnvironmentsAsync();
        await ReloadAsync(force: false);
    });

    /// <summary>
    /// Discover environments via <c>GetEnvironments</c> on each candidate context, then order them
    /// using <see cref="EnvironmentOrdering.Order"/> with either the host-supplied
    /// <see cref="EnvironmentOrder"/> or the options-level <see cref="ApplicationInsightsOptions.EnvironmentOrder"/>.
    /// </summary>
    private async Task LoadEnvironmentsAsync()
    {
        try
        {
            var contexts = ResolveAllContexts();
            var set = new HashSet<string>(System.StringComparer.OrdinalIgnoreCase);
            foreach (var ctx in contexts)
            {
                await foreach (var env in Ai.GetEnvironments(ctx))
                {
                    if (!string.IsNullOrWhiteSpace(env.Value)) set.Add(env.Value);
                }
            }
            var order = EnvironmentOrder ?? AiOptions.Value.EnvironmentOrder;
            _candidateEnvironments = EnvironmentOrdering.Order(set, order)
                // EnvironmentOrdering appends the "(unknown)" sentinel for blank rows — we filter
                // those out of the selectable set because the cube already carries the empty-string
                // environment, which the "no selection = all" path handles transparently.
                .Where(e => e != EnvironmentOrderingUnknownSentinel)
                .ToArray();

            // Drop any selected env that disappeared so the chip state doesn't lie.
            _selectedEnvironments = _selectedEnvironments?
                .Where(e => _candidateEnvironments.Contains(e, System.StringComparer.OrdinalIgnoreCase))
                .ToArray() ?? [];
        }
        catch (System.Exception)
        {
            _candidateEnvironments = [];
            _selectedEnvironments = [];
        }
    }

    /// <summary>EnvironmentOrdering's internal sentinel is "(unknown)" — same literal here.</summary>
    private const string EnvironmentOrderingUnknownSentinel = "(unknown)";

    private IReadOnlyList<IApplicationInsightsContext> ResolveAllContexts()
    {
        if (Context != null) return [Context];
        if (_candidateConfigs.Count == 0) return [];
        return _candidateConfigs.Cast<IApplicationInsightsContext>().ToArray();
    }

    private async Task OnRangeChangedAsync()
    {
        // Range changes are the only filter that triggers a fetch. Cached ranges return instantly.
        await ReloadAsync(force: false);
    }

    /// <summary>
    /// Ensure the current range is in the cache (fetching from every candidate config in parallel
    /// if not), then regroup into _rows. <paramref name="force"/> evicts the current range's
    /// cache entry first — what the Refresh button does.
    /// </summary>
    private async Task ReloadAsync(bool force)
    {
        var contexts = ResolveAllContexts();
        if (contexts.Count == 0)
        {
            _rows = [];
            _columnTotals = NewEmptyTotals();
            _grandTotal = 0;
            return;
        }

        if (force)
        {
            _cellCache.Remove(_window);
        }

        if (!_cellCache.ContainsKey(_window))
        {
            _busy = true;
            _loadError = null;
            StateHasChanged();
            try
            {
                // Parallel fan-out across configs — each Log Analytics query is independent and
                // typically takes seconds; running them in sequence multiplies the wait.
                var range = _window;
                var perContext = await System.Threading.Tasks.Task.WhenAll(contexts.Select(async ctx =>
                {
                    var configId = (ctx as ApplicationInsightsConfigurationResponse)?.Id ?? "";
                    var cells = await Ai.GetLogCountByServiceAsync(ctx, range).ToArrayAsync();
                    return cells.Select(c => new TaggedCell(configId, c)).ToArray();
                }));
                _cellCache[_window] = perContext.SelectMany(x => x).ToList();
            }
            catch (System.Exception e)
            {
                _loadError = e.Message;
                _cellCache[_window] = [];
            }
            finally
            {
                _busy = false;
            }
        }

        RecomputeRows();
        StateHasChanged();
    }

    /// <summary>
    /// Pure client-side: slice the cached cell cube by the current configuration / environment /
    /// source selections (empty selection = include all), aggregate counts by (service, severity),
    /// and rebuild the column totals + grand total for the pinned footer row. Called whenever any
    /// non-range filter toggles.
    /// </summary>
    private void RecomputeRows()
    {
        if (!_cellCache.TryGetValue(_window, out var allCells))
        {
            _rows = [];
            _columnTotals = NewEmptyTotals();
            _grandTotal = 0;
            return;
        }

        var configSet = (_selectedConfigIds ?? []).ToHashSet(System.StringComparer.OrdinalIgnoreCase);
        var envSet = (_selectedEnvironments ?? []).ToHashSet(System.StringComparer.OrdinalIgnoreCase);
        var sourceSet = (_selectedSources ?? []).ToHashSet();

        var aggregated = new Dictionary<(string Service, SeverityLevel Severity), long>();
        foreach (var t in allCells)
        {
            if (configSet.Count > 0 && !configSet.Contains(t.ConfigId)) continue;
            if (envSet.Count > 0 && !envSet.Contains(t.Cell.Environment)) continue;
            if (sourceSet.Count > 0 && !sourceSet.Contains(t.Cell.Source)) continue;

            var key = (t.Cell.Service ?? "unknown", t.Cell.Severity);
            aggregated[key] = aggregated.GetValueOrDefault(key) + t.Cell.Count;
        }

        _rows = aggregated
            .GroupBy(kvp => kvp.Key.Service, System.StringComparer.OrdinalIgnoreCase)
            .OrderBy(g => g.Key, System.StringComparer.OrdinalIgnoreCase)
            .Select(g => new ServiceRow(g.Key, g.ToDictionary(kvp => kvp.Key.Severity, kvp => kvp.Value)))
            .ToList();

        _columnTotals = NewEmptyTotals();
        foreach (var row in _rows)
        {
            foreach (var sev in (SeverityLevel[])System.Enum.GetValues(typeof(SeverityLevel)))
            {
                _columnTotals[sev] += row.GetCount(sev);
            }
        }
        _grandTotal = _rows.Sum(r => r.Total);
    }

    private static Dictionary<SeverityLevel, long> NewEmptyTotals()
    {
        var d = new Dictionary<SeverityLevel, long>();
        foreach (var sev in (SeverityLevel[])System.Enum.GetValues(typeof(SeverityLevel)))
        {
            d[sev] = 0L;
        }
        return d;
    }

    public void Dispose()
    {
        if (_selector != null) _selector.OnChanged -= OnSelectorChanged;
    }

    /// <summary>Cell + the id of the configuration it came from, for the local configuration filter.</summary>
    private sealed record TaggedCell(string ConfigId, LogCountByServiceCell Cell);

    /// <summary>
    /// Row shape with one explicit property per severity so the grid can sort each amount column
    /// numerically — sort works off of the property name, not a runtime Template expression.
    /// </summary>
    private sealed class ServiceRow
    {
        private readonly IReadOnlyDictionary<SeverityLevel, long> _counts;

        public ServiceRow(string service, IReadOnlyDictionary<SeverityLevel, long> counts)
        {
            Service = service;
            _counts = counts;
            Total = counts.Values.Sum();
        }

        public string Service { get; }
        public long Verbose => GetCount(SeverityLevel.Verbose);
        public long Information => GetCount(SeverityLevel.Information);
        public long Warning => GetCount(SeverityLevel.Warning);
        public long Error => GetCount(SeverityLevel.Error);
        public long Critical => GetCount(SeverityLevel.Critical);
        public long Total { get; }
        public long GetCount(SeverityLevel s) => _counts.TryGetValue(s, out var v) ? v : 0;
    }
}
