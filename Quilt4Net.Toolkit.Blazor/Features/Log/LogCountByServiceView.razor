@using Microsoft.Extensions.DependencyInjection
@using Quilt4Net.Toolkit.Blazor.Features.ApplicationInsights
@using Quilt4Net.Toolkit.Features.ApplicationInsights
@inject IServiceProvider ServiceProvider
@inject IApplicationInsightsService Ai
@implements IDisposable

@* Pivot table of log counts: rows = services (AppRoleName / Properties.ApplicationName), columns
   = severity levels. Mirrors LogView / MetricsView wiring (workspace dropdown, range selector,
   environment filter) so the three compose on the same page and the same operator habits transfer. *@

@if (_configError != null)
{
    <RadzenAlert AlertStyle="AlertStyle.Info" Shade="Shade.Lighter" AllowClose="false">@_configError</RadzenAlert>
    return;
}

<RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
    <RadzenRow AlignItems="AlignItems.End" Gap="1rem">
        @if (_selector != null && _selector.Available.Count > 1)
        {
            <RadzenColumn>
                <ApplicationInsightsConfigurationDropdown />
            </RadzenColumn>
        }
        else if (Configs is { Count: > 1 })
        {
            <RadzenColumn>
                <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                    <RadzenText TextStyle="TextStyle.Caption" Text="Configuration" />
                    <RadzenDropDown Data="@Configs" @bind-Value="_selectedConfig" TValue="ApplicationInsightsConfigurationResponse"
                                    TextProperty="Name" Change="@(_ => ReloadAsync())" />
                </RadzenStack>
            </RadzenColumn>
        }
        <RadzenColumn>
            <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                <RadzenText TextStyle="TextStyle.Caption" Text="Range" />
                <RadzenSelectBar @bind-Value="_window" TValue="System.TimeSpan" Size="ButtonSize.Small"
                                 Change="@(_ => ReloadAsync())">
                    <Items>
                        <RadzenSelectBarItem Text="1h" Value="@System.TimeSpan.FromHours(1)" />
                        <RadzenSelectBarItem Text="24h" Value="@System.TimeSpan.FromHours(24)" />
                        <RadzenSelectBarItem Text="7d" Value="@System.TimeSpan.FromDays(7)" />
                    </Items>
                </RadzenSelectBar>
            </RadzenStack>
        </RadzenColumn>
        <RadzenColumn>
            <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                <RadzenText TextStyle="TextStyle.Caption" Text="Environment" />
                <LogEnvironmentSelector OnSelected="OnEnvironmentSelected" Context="EffectiveContext" />
            </RadzenStack>
        </RadzenColumn>
        <RadzenColumn>
            <RadzenButton Icon="refresh" Text="Refresh" ButtonStyle="ButtonStyle.Light"
                          IsBusy="@_busy" Click="@(_ => ReloadAsync())" />
        </RadzenColumn>
    </RadzenRow>

    @if (_loadError != null)
    {
        <RadzenAlert AlertStyle="AlertStyle.Warning" Shade="Shade.Lighter" AllowClose="false">
            Could not query Application Insights: @_loadError
        </RadzenAlert>
    }

    @if (_rows.Count == 0 && !_busy)
    {
        <RadzenAlert AlertStyle="AlertStyle.Info" Shade="Shade.Lighter" AllowClose="false">
            No log entries in the selected range / environment.
        </RadzenAlert>
    }
    else
    {
        <RadzenDataGrid Data="@_rows" TItem="ServiceRow" AllowSorting="true">
            <Columns>
                <RadzenDataGridColumn TItem="ServiceRow" Title="Service" Property="@nameof(ServiceRow.Service)" SortOrder="SortOrder.Ascending" />
                @foreach (var sev in Severities)
                {
                    var s = sev;
                    <RadzenDataGridColumn TItem="ServiceRow" Title="@s.ToString()" Width="120px" TextAlign="TextAlign.Right">
                        <Template Context="row">@row.GetCount(s)</Template>
                    </RadzenDataGridColumn>
                }
                <RadzenDataGridColumn TItem="ServiceRow" Title="Total" Property="@nameof(ServiceRow.Total)" Width="120px" TextAlign="TextAlign.Right" />
            </Columns>
        </RadzenDataGrid>
    }
</RadzenStack>

@code {
    // Render every severity column even when its count is zero across all services — keeps the
    // grid layout stable across reloads / windows. Ordered low-to-high so reading left-to-right
    // walks from informational to critical.
    private static readonly SeverityLevel[] Severities =
    [
        SeverityLevel.Verbose,
        SeverityLevel.Information,
        SeverityLevel.Warning,
        SeverityLevel.Error,
        SeverityLevel.Critical,
    ];

    private string _configError;
    private string _loadError;
    private bool _busy;
    private System.TimeSpan _window = System.TimeSpan.FromHours(24);
    private string _environment;
    private List<ServiceRow> _rows = [];

    private IApplicationInsightsConfigurationSelector _selector;
    private ApplicationInsightsConfigurationResponse _selectedConfig;

    /// <summary>Optional explicit context. When set, the selector is ignored.</summary>
    [Parameter]
    public IApplicationInsightsContext Context { get; set; }

    /// <summary>
    /// Optional explicit set of configurations to pick from. When more than one is supplied a
    /// dropdown is rendered. Takes precedence over the DI selector; ignored when <see cref="Context"/>
    /// is set. Mirrors LogView / MetricsView so the three compose on the same page.
    /// </summary>
    [Parameter]
    public IReadOnlyList<ApplicationInsightsConfigurationResponse> Configs { get; set; }

    private IApplicationInsightsContext EffectiveContext
        => Context ?? _selectedConfig ?? _selector?.Selected;

    protected override async Task OnInitializedAsync()
    {
        if (Context == null && Configs is not { Count: > 0 })
        {
            _selector = ServiceProvider.GetService<IApplicationInsightsConfigurationSelector>();
            if (_selector != null)
            {
                _selector.OnChanged += OnSelectorChanged;
                if (!_selector.IsLoaded) await _selector.LoadAsync();
            }
        }

        if (Configs is { Count: > 0 } && _selectedConfig == null)
        {
            _selectedConfig = Configs[0];
        }

        if (EffectiveContext == null)
        {
            _configError = "No Application Insights configuration available.";
            return;
        }

        await ReloadAsync();
    }

    private async void OnSelectorChanged() => await InvokeAsync(ReloadAsync);

    private async Task OnEnvironmentSelected(EnvironmentOption environment)
    {
        // EnvironmentOption has an implicit conversion to its Value string; null means "all envs".
        _environment = environment?.Value;
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        var ctx = EffectiveContext;
        if (ctx == null) return;
        _busy = true;
        _loadError = null;
        StateHasChanged();
        try
        {
            var cells = await Ai.GetLogCountByServiceAsync(ctx, _environment, _window).ToArrayAsync();
            _rows = cells
                .GroupBy(c => c.Service ?? "unknown")
                .OrderBy(g => g.Key, System.StringComparer.OrdinalIgnoreCase)
                .Select(g => new ServiceRow(g.Key, g.ToDictionary(c => c.Severity, c => c.Count)))
                .ToList();
        }
        catch (System.Exception e)
        {
            _loadError = e.Message;
            _rows = [];
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        if (_selector != null) _selector.OnChanged -= OnSelectorChanged;
    }

    private sealed class ServiceRow
    {
        public ServiceRow(string service, IReadOnlyDictionary<SeverityLevel, long> counts)
        {
            Service = service;
            _counts = counts;
            Total = counts.Values.Sum();
        }

        private readonly IReadOnlyDictionary<SeverityLevel, long> _counts;

        public string Service { get; }
        public long Total { get; }
        public long GetCount(SeverityLevel s) => _counts.TryGetValue(s, out var v) ? v : 0;
    }
}
