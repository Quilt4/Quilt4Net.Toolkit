@using Microsoft.Extensions.DependencyInjection
@using Quilt4Net.Toolkit.Features.ApplicationInsights
@using Tharga.Blazor.Features.BreadCrumbs
@inject NavigationManager NavigationManager
@inject IServiceProvider ServiceProvider

<CascadingValue Value="_navOptions">
    <RadzenRow Style="margin-bottom: 6px;" Visible="@(ShowRangeSelector || ShowEnvironmentSelector)">
        <RadzenColumn Visible="@ShowRangeSelector">
            <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                <RadzenText TextStyle="TextStyle.Caption" Text="Range"/>
                <LogRangeSelector OnSelected="OnRangeSelected" />
            </RadzenStack>
        </RadzenColumn>
        <RadzenColumn Visible="@ShowEnvironmentSelector">
            <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                <RadzenText TextStyle="TextStyle.Caption" Text="Environment" />
                <LogEnvironmentSelector OnSelected="OnEnvironmentSelected" Context="@Context" />
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>

    <RadzenTabs SelectedIndex="@_tabIndex" Change="@OnTabChange">
        <Tabs>
            <RadzenTabsItem Text="Search">
                <LogSearchView Range="@RangeToUse" Environment="@EnvironmentToUse" Context="Context" />
            </RadzenTabsItem>
            <RadzenTabsItem Text="Summary">
                <LogSummaryListView Range="@RangeToUse" Environment="@EnvironmentToUse" Context="Context" />
            </RadzenTabsItem>
            <RadzenTabsItem Text="Measure">
                <LogMeasureView Range="@RangeToUse" Environment="@EnvironmentToUse" Context="Context" />
            </RadzenTabsItem>
            <RadzenTabsItem Text="Count">
                <LogCountView Range="@RangeToUse" Environment="@EnvironmentToUse" Context="Context" />
            </RadzenTabsItem>
            <RadzenTabsItem Text="Trigger" Visible="@(Context == null)">
                <LogTriggerView Context="Context" />
            </RadzenTabsItem>
        </Tabs>
    </RadzenTabs>
</CascadingValue>

@code {
    private static readonly string[] TabNames = ["search", "summary", "measure", "count", "trigger"];

    private LogRangeSelector.TimeRangeOption _range;
    private EnvironmentOption _environment;
    private LogNavigationOptions _navOptions;
    private int _tabIndex;

    [Parameter]
    public bool ShowRangeSelector { get; set; } = true;

    [Parameter]
    public TimeSpan? Range { get; set; }

    [Parameter]
    public bool ShowEnvironmentSelector { get; set; } = true;

    [Parameter]
    public string Environment { get; set; }

    [Parameter]
    public IApplicationInsightsContext Context { get; set; }

    /// <summary>
    /// Optional path for the log detail page, e.g. "/log/detail".
    /// When null (default), clicking a detail link opens a dialog instead of navigating.
    /// </summary>
    [Parameter]
    public string DetailPath { get; set; }

    /// <summary>
    /// Optional path for the log summary page, e.g. "/log/summary".
    /// When null (default), clicking a summary link opens a dialog instead of navigating.
    /// </summary>
    [Parameter]
    public string SummaryPath { get; set; }

    /// <summary>
    /// The initially selected tab name (e.g. "summary"). Case-insensitive.
    /// Typically bound from a query parameter: <c>[Parameter, SupplyParameterFromQuery] public string Tab { get; set; }</c>
    /// </summary>
    [Parameter]
    public string Tab { get; set; }

    /// <summary>
    /// Fires when the user switches tabs, passing the new tab name (lowercase).
    /// </summary>
    [Parameter]
    public EventCallback<string> OnTabChanged { get; set; }

    private TimeSpan RangeToUse => ShowRangeSelector
        ? _range
        : (Range ?? TimeSpan.Zero);
    private string EnvironmentToUse => ShowEnvironmentSelector
        ? _environment
        : Environment;

    protected override void OnParametersSet()
    {
        _navOptions = new LogNavigationOptions
        {
            DetailPath = DetailPath,
            SummaryPath = SummaryPath
        };

        var idx = Array.IndexOf(TabNames, Tab?.ToLower() ?? string.Empty);
        _tabIndex = idx >= 0 ? idx : 0;

        var breadCrumbService = ServiceProvider.GetService<BreadCrumbService>();
        var tabName = TabNames[_tabIndex];
        breadCrumbService?.RemoveVirtualSegments();
        breadCrumbService?.AddVirtualSegment(tabName);
    }

    private async Task OnTabChange(int index)
    {
        _tabIndex = index;
        var tabName = index < TabNames.Length ? TabNames[index] : TabNames[0];

        var breadCrumbService = ServiceProvider.GetService<BreadCrumbService>();
        breadCrumbService?.RemoveVirtualSegments();
        breadCrumbService?.AddVirtualSegment(tabName);

        var uri = NavigationManager.GetUriWithQueryParameter("tab", tabName);
        NavigationManager.NavigateTo(uri, replace: true);

        if (OnTabChanged.HasDelegate)
            await OnTabChanged.InvokeAsync(tabName);
    }

    private void OnRangeSelected(LogRangeSelector.TimeRangeOption range)
    {
        _range = range;
        StateHasChanged();
    }

    private void OnEnvironmentSelected(EnvironmentOption environment)
    {
        _environment = environment;
        StateHasChanged();
    }
}
