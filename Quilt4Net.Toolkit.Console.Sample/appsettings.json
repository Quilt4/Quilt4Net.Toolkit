{
  "DetailedErrors": true,
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "ApplicationInsights": {
      "LogLevel": {
        "Default": "Information",
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "Quilt4Net": {
    "Quilt4NetAddress": "https://localhost:7129/"
    // ApiKey and ApplicationInsights:ConnectionString are set via user-secrets
    // (differ per dev machine). Run: dotnet user-secrets set "Quilt4Net:ApiKey" "..."
  }
}
