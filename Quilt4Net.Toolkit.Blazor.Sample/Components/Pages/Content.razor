@page "/content"
@rendermode InteractiveServer

<PageTitle>Content</PageTitle>

<h1>Content management</h1>

<p>
    Enable edit mode using the <strong>ContentAdmin</strong> toggle in the top bar.
    When enabled, content components show a pink dotted outline and open an edit dialog on click.
</p>

<h3>Quilt4Text</h3>
<Quilt4Text Key="sample-h1" Default="Heading 1 example" TextStyle="TextStyle.H1" />
<Quilt4Text Key="sample-h3" Default="Heading 3 example" TextStyle="TextStyle.H3" />
<Quilt4Text Key="sample-body" Default="Body text example" TextStyle="TextStyle.Body1" />

<h3>Quilt4Content</h3>
<Quilt4Content Key="sample-rich">
    <p>This is <strong>rich HTML content</strong> with <em>formatting</em> and a <a href="https://quilt4net.com">link</a>.</p>
</Quilt4Content>

<h3>Quilt4Span and Quilt4Raw</h3>
<p>
    <Quilt4Span Key="inline-label" Default="Inline label:" />
    <Quilt4Raw Key="inline-value" Default="raw value" />
</p>

<h3>Quilt4Button</h3>
<Quilt4Button TextKey="content-action" DefaultText="Content action" Icon="edit" Click="@OnClick" />
<p style="margin-top: 8px; color: gray;">@_message</p>

@code {
    private string _message = "";

    private Task OnClick()
    {
        _message = $"Action triggered at {DateTime.Now:HH:mm:ss}";
        StateHasChanged();
        return Task.CompletedTask;
    }
}
